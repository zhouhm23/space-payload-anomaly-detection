# PHM ground-segment environment template.
# Copy to .env and fill in real values. The .env file is gitignored.
#
# These are SECRETS / deployment-specific — they stay out of system_config.json
# (which is for non-secret tuning). Non-secret LLM params (timeout) live in
# system_config.json under the "llm" section.

# LLM diagnosis API key (OpenAI-compatible endpoint).
# For Zhipu GLM: https://open.bigmodel.cn/  → API keys.
OPENAI_API_KEY=

# LLM API base URL (OpenAI-compatible). Examples:
#   Zhipu GLM:      https://open.bigmodel.cn/api/paas/v4
#   DeepSeek:       https://api.deepseek.com/v1
#   Moonshot KMS:   https://api.moonshot.cn/v1
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# LLM model id. Vision models (suffix -V) accept PNG waveform images and
# achieve ~75% verdict accuracy vs ~58% for text-only models.
# Zhipu options: GLM-4V-Flash (free, vision), GLM-4-Flash (text).
LLM_MODEL=GLM-4V-Flash
