.conda-env
.pytest_cache
.hf_cache
.env
!.env.example
__pycache__
ground/device_config.json
# ground/data/ holds runtime artifacts. Ignore everything EXCEPT the product
# config JSONs (system_config / ui_theme / channel_calibration) which are
# versioned assets. phm.db and scratch files stay ignored.
ground/data/*
!ground/data/system_config.json
!ground/data/ui_theme.json
!ground/data/channel_calibration.json
# Model weights (large binary) — keep scaler/config JSONs, exclude .pt
*.pt
# Vue3 前端 build 产物（部署时现场 npm run build:no-check 生成，不入库）
ground/django_phm/static/phm_site/dist/